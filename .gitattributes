# Normalize line endings: store as LF, check out as native on Windows
* text=auto eol=lf

# Explicitly CRLF on Windows-only files
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary — never rewrite
*.png   binary
*.ico   binary
*.dll   binary
*.exe   binary
*.zip   binary
*.msix  binary
*.pdf   binary
